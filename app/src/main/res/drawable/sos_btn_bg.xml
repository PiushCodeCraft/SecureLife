<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#CC0A22"/>
            <stroke android:width="2dp" android:color="#FF2847"/>
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF2847"/>
            <stroke android:width="2dp" android:color="#80FF2847"/>
        </shape>
    </item>

</selector>
