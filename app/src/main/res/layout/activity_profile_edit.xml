<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06080F"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ── TOP NAV ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:background="@drawable/toolbar_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="← Back"
                android:textSize="13sp"
                android:textColor="#8492B4"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="My Profile"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F0F4FF" />

        </RelativeLayout>

        <!-- ── AVATAR ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:text="👤"
                android:textSize="32sp"
                android:gravity="center"
                android:background="@drawable/avatar_bg"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#F0F4FF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age: -"
                android:textSize="12sp"
                android:textColor="#2E3A52" />

        </LinearLayout>

        <!-- ── EMERGENCY CONTACTS CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/card_form_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <!-- Section title -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMERGENCY CONTACTS"
                    android:textSize="9sp"
                    android:letterSpacing="0.15"
                    android:textColor="#FF2847"
                    android:layout_centerVertical="true" />

                <!-- Edit button -->
                <Button
                    android:id="@+id/btnEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="✏ Edit"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:background="@drawable/btn_logout_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:stateListAnimator="@null"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />

                <!-- Save button (hidden initially) -->
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Save"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_save_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:stateListAnimator="@null"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:visibility="gone" />

            </RelativeLayout>

            <!-- Contact 1 label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTACT 1"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textColor="#2E3A52"
                android:layout_marginBottom="8dp" />

            <!-- Contact 1 Name — VIEW -->
            <TextView
                android:id="@+id/tvContact1Name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#F0F4FF"
                android:layout_marginBottom="4dp" />

            <!-- Contact 1 Number — VIEW -->
            <TextView
                android:id="@+id/tvContact1Number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="13sp"
                android:textColor="#FF2847"
                android:layout_marginBottom="16dp" />

            <!-- Contact 1 Name — EDIT -->
            <EditText
                android:id="@+id/etContact1Name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contact 1 Name"
                android:textColorHint="#2E3A52"
                android:textColor="#F0F4FF"
                android:textSize="14sp"
                android:background="@drawable/input_field_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPersonName"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- Contact 1 Number — EDIT -->
            <EditText
                android:id="@+id/etContact1Number"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contact 1 Number"
                android:textColorHint="#2E3A52"
                android:textColor="#F0F4FF"
                android:textSize="14sp"
                android:background="@drawable/input_field_bg_red"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="phone"
                android:visibility="gone"
                android:layout_marginBottom="20dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#1A2E52"
                android:layout_marginBottom="16dp" />

            <!-- Contact 2 label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTACT 2"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textColor="#2E3A52"
                android:layout_marginBottom="8dp" />

            <!-- Contact 2 Name — VIEW -->
            <TextView
                android:id="@+id/tvContact2Name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#F0F4FF"
                android:layout_marginBottom="4dp" />

            <!-- Contact 2 Number — VIEW -->
            <TextView
                android:id="@+id/tvContact2Number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="13sp"
                android:textColor="#FF2847" />

            <!-- Contact 2 Name — EDIT -->
            <EditText
                android:id="@+id/etContact2Name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contact 2 Name"
                android:textColorHint="#2E3A52"
                android:textColor="#F0F4FF"
                android:textSize="14sp"
                android:background="@drawable/input_field_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPersonName"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <!-- Contact 2 Number — EDIT -->
            <EditText
                android:id="@+id/etContact2Number"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contact 2 Number"
                android:textColorHint="#2E3A52"
                android:textColor="#F0F4FF"
                android:textSize="14sp"
                android:background="@drawable/input_field_bg_red"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="phone"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
