<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06080F"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Up Your Profile"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#F0F4FF"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This helps us keep you safe"
            android:textSize="13sp"
            android:textColor="#2E3A52"
            android:layout_marginBottom="32dp" />

        <!-- ── PERSONAL DETAILS ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERSONAL DETAILS"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textColor="#2E3A52"
            android:layout_marginBottom="12dp" />

        <!-- Name -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Full Name"
            android:textColorHint="#2E3A52"
            android:textColor="#F0F4FF"
            android:textSize="14sp"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_field_bg"
            android:layout_marginBottom="12dp" />

        <!-- Age -->
        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Age"
            android:textColorHint="#2E3A52"
            android:textColor="#F0F4FF"
            android:textSize="14sp"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_field_bg"
            android:layout_marginBottom="28dp" />

        <!-- ── EMERGENCY CONTACT 1 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACT 1"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textColor="#FF2847"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etContact1Name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Contact Name"
            android:textColorHint="#2E3A52"
            android:textColor="#F0F4FF"
            android:textSize="14sp"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_field_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etContact1Number"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Phone Number"
            android:textColorHint="#2E3A52"
            android:textColor="#F0F4FF"
            android:textSize="14sp"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_field_bg_red"
            android:layout_marginBottom="28dp" />

        <!-- ── EMERGENCY CONTACT 2 ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMERGENCY CONTACT 2"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textColor="#FF2847"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etContact2Name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Contact Name"
            android:textColorHint="#2E3A52"
            android:textColor="#F0F4FF"
            android:textSize="14sp"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_field_bg"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etContact2Number"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Phone Number"
            android:textColorHint="#2E3A52"
            android:textColor="#F0F4FF"
            android:textSize="14sp"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_field_bg_red"
            android:layout_marginBottom="36dp" />

        <!-- Next Button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Next →"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_save_bg"
            android:stateListAnimator="@null"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>