<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06080F"
    tools:context=".MainActivity">

    <!-- ══════════════════════════════
         TOP TOOLBAR — pinned to top
         ══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/toolbar_bg"
        android:layout_alignParentTop="true">

        <ImageView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_securelife_logo"
            android:layout_marginEnd="10dp"
            android:contentDescription="SecureLife Logo" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SecureLife"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F0F4FF" />

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Logout"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF2847"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/btn_logout_bg"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- ══════════════════════════════
         BOTTOM PANEL — pinned to bottom
         ══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:background="@drawable/panel_bottom_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp">

        <!-- Panel header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <TextView
                android:text="EMERGENCY SERVICES"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textColor="#2E3A52"
                android:layout_centerVertical="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:text="6 ACTIVE"
                android:textSize="9sp"
                android:textColor="#FF2847"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/badge_red_bg"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </RelativeLayout>

        <!-- Row 1: Emergency | Police | Hospital -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:id="@+id/contactBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_emergency"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_call"
                    android:background="@drawable/icon_bg_red"
                    android:padding="12dp"
                    android:tint="#FF2847"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:text="Emergency"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/policeBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_police"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:background="@drawable/icon_bg_blue"
                    android:padding="12dp"
                    android:tint="#2F80ED"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:text="Police"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/hospitalBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_hospital"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:background="@drawable/icon_bg_green"
                    android:padding="12dp"
                    android:tint="#00D68F"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:text="Hospital"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

        <!-- Row 2: Petrol | Location | Profile -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/petrolBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_petrol"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_directions"
                    android:background="@drawable/icon_bg_orange"
                    android:padding="12dp"
                    android:tint="#FF6B35"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:text="Petrol"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/locationBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_location"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:background="@drawable/icon_bg_purple"
                    android:padding="12dp"
                    android:tint="#7C3AED"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:text="Location"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Profile Button -->
            <LinearLayout
                android:id="@+id/profileBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/card_police"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:background="@drawable/icon_bg_red"
                    android:padding="12dp"
                    android:tint="#FF2847"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:text="Profile"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#F0F4FF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════
         MIDDLE AREA — between toolbar
         and bottom panel
         SOS button perfectly centered
         ══════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:layout_above="@id/bottomPanel">

        <!-- Welcome text top left -->
        <TextView
            android:id="@+id/userName"
            android:text="Welcome, User"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F0F4FF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp" />

        <!-- SOS rings + button — perfectly centered -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true">

            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_outer"
                android:alpha="0.5" />

            <View
                android:layout_width="196dp"
                android:layout_height="196dp"
                android:layout_gravity="center"
                android:background="@drawable/ring_middle"
                android:alpha="0.4" />

            <Button
                android:id="@+id/sosBtn"
                android:text="SOS"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/sos_btn_bg"
                android:layout_gravity="center"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                android:layout_width="165dp"
                android:layout_height="165dp" />

        </FrameLayout>

        <!-- SOS hint at bottom of middle area -->
        <TextView
            android:id="@+id/sosHint"
            android:text="TAP TO ACTIVATE · HOLD TO STOP"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textColor="#2E3A52"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="12dp" />

    </RelativeLayout>

</RelativeLayout>